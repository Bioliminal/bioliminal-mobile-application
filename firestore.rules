rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /assessments/{uid}/sessions/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /reports/{uid}/sessions/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
