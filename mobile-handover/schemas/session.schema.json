{
  "$defs": {
    "ConsentMetadata": {
      "additionalProperties": true,
      "description": "Session-level consent fingerprint. Required when emg is present; see\nSession.validate_consent_for_emg.",
      "properties": {
        "consent_version": {
          "title": "Consent Version",
          "type": "string"
        },
        "consent_jurisdiction": {
          "enum": [
            "US-WA",
            "US-other",
            "EU",
            "other"
          ],
          "title": "Consent Jurisdiction",
          "type": "string"
        },
        "consent_timestamp": {
          "format": "date-time",
          "title": "Consent Timestamp",
          "type": "string"
        },
        "data_retention_days": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data Retention Days"
        }
      },
      "required": [
        "consent_version",
        "consent_jurisdiction",
        "consent_timestamp"
      ],
      "title": "ConsentMetadata",
      "type": "object"
    },
    "Frame": {
      "description": "A single captured frame with 33 BlazePose landmarks in canonical order.",
      "properties": {
        "timestamp_ms": {
          "minimum": 0,
          "title": "Timestamp Ms",
          "type": "integer"
        },
        "landmarks": {
          "items": {
            "$ref": "#/$defs/Landmark"
          },
          "title": "Landmarks",
          "type": "array"
        }
      },
      "required": [
        "timestamp_ms",
        "landmarks"
      ],
      "title": "Frame",
      "type": "object"
    },
    "Landmark": {
      "description": "Single BlazePose landmark.\n\nCoordinates in normalized [0, 1] space (x, y) or input-relative (z).\nVisibility and presence are sigmoid'd values in [0, 1].",
      "properties": {
        "x": {
          "title": "X",
          "type": "number"
        },
        "y": {
          "title": "Y",
          "type": "number"
        },
        "z": {
          "title": "Z",
          "type": "number"
        },
        "visibility": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Visibility",
          "type": "number"
        },
        "presence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Presence",
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z",
        "visibility",
        "presence"
      ],
      "title": "Landmark",
      "type": "object"
    },
    "SessionMetadata": {
      "properties": {
        "movement": {
          "enum": [
            "overhead_squat",
            "single_leg_squat",
            "push_up",
            "rollup",
            "bicep_curl"
          ],
          "title": "Movement",
          "type": "string"
        },
        "device": {
          "title": "Device",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "frame_rate": {
          "exclusiveMinimum": 0,
          "title": "Frame Rate",
          "type": "number"
        },
        "captured_at": {
          "format": "date-time",
          "title": "Captured At",
          "type": "string"
        }
      },
      "required": [
        "movement",
        "device",
        "model",
        "frame_rate"
      ],
      "title": "SessionMetadata",
      "type": "object"
    },
    "sEMGSample": {
      "additionalProperties": true,
      "description": "Single sEMG reading. Schema is intentionally minimal pending gitlab\nML_RandD_Server#13 (sEMG in SessionPayload decision); extra fields permitted\nvia extra='allow' for forward compatibility with channel metadata, windowing,\nand feature-extraction parameters.",
      "properties": {
        "channel": {
          "minimum": 0,
          "title": "Channel",
          "type": "integer"
        },
        "timestamp_ms": {
          "minimum": 0,
          "title": "Timestamp Ms",
          "type": "integer"
        },
        "value": {
          "title": "Value",
          "type": "number"
        },
        "encoding": {
          "default": "normalized_0_1",
          "enum": [
            "raw_mv",
            "normalized_0_1",
            "feature_rms",
            "feature_mdf"
          ],
          "title": "Encoding",
          "type": "string"
        }
      },
      "required": [
        "channel",
        "timestamp_ms",
        "value"
      ],
      "title": "sEMGSample",
      "type": "object"
    }
  },
  "properties": {
    "metadata": {
      "$ref": "#/$defs/SessionMetadata"
    },
    "frames": {
      "items": {
        "$ref": "#/$defs/Frame"
      },
      "title": "Frames",
      "type": "array"
    },
    "emg": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/sEMGSample"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Emg"
    },
    "consent": {
      "anyOf": [
        {
          "$ref": "#/$defs/ConsentMetadata"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "metadata",
    "frames"
  ],
  "title": "Session",
  "type": "object"
}
