{
  "hosting": {
    "public": "build/web",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "predeploy": [
      "mkdir -p build/web/deck/demo && cp showcase/showcase-day-noon-dry-run-deck.html build/web/deck/index.html && cp showcase/QR_code_Showcase_Day-Deck.png build/web/deck/ && cp showcase/PXL_20260420_145134008.TS.mp4 build/web/deck/ && cp showcase/slide1.png build/web/deck/ && cp showcase/Logo.png build/web/deck/ && cp showcase/arnold.webp build/web/deck/ && cp showcase/aaron.png build/web/deck/ && cp showcase/demo.html build/web/deck/demo/index.html"
    ],
    "rewrites": [
      {"source": "/deck", "destination": "/deck/index.html"},
      {"source": "/deck/demo", "destination": "/deck/demo/index.html"},
      {"source": "**", "destination": "/index.html"}
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "bioliminal",
          "appId": "1:567938947764:android:ba6fb50e2357c63e5315e1",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "bioliminal",
          "appId": "1:567938947764:ios:ddebc788ea471e055315e1",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "bioliminal",
          "configurations": {
            "android": "1:567938947764:android:ba6fb50e2357c63e5315e1",
            "ios": "1:567938947764:ios:ddebc788ea471e055315e1",
            "web": "1:567938947764:web:34e6275ef5c542b75315e1"
          }
        }
      }
    }
  }
}
