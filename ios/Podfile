# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  # MediaPipe Tasks Vision — direct binding for BlazePose Full inference.
  # See plans/native-mediapipe-pose-integration.md.
  pod 'MediaPipeTasksVision', '~> 0.10.14'

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # Workaround: MediaPipeTasksCommon and MediaPipeTasksVision ship as
  # static-archive xcframeworks. CocoaPods doesn't generate the xcframework
  # slice-extraction script for these pods (their targets are PBXAggregate),
  # so the standard `-l"X"` link flags can't find anything. Patch Runner's
  # xcconfig to:
  #   - Use -framework instead of -l for both pods.
  #   - Point FRAMEWORK_SEARCH_PATHS directly into the right xcframework
  #     slice, per platform — Xcode resolves -framework X by looking for
  #     X.framework inside FRAMEWORK_SEARCH_PATHS.
  pods_runner_dir = File.join(installer.config.installation_root, 'Pods', 'Target Support Files', 'Pods-Runner')
  device_paths = '"${PODS_ROOT}/MediaPipeTasksCommon/frameworks/MediaPipeTasksCommon.xcframework/ios-arm64" "${PODS_ROOT}/MediaPipeTasksVision/frameworks/MediaPipeTasksVision.xcframework/ios-arm64"'
  sim_paths = '"${PODS_ROOT}/MediaPipeTasksCommon/frameworks/MediaPipeTasksCommon.xcframework/ios-arm64_x86_64-simulator" "${PODS_ROOT}/MediaPipeTasksVision/frameworks/MediaPipeTasksVision.xcframework/ios-arm64_x86_64-simulator"'

  Dir.glob(File.join(pods_runner_dir, 'Pods-Runner.*.xcconfig')).each do |xcconfig|
    text = File.read(xcconfig)
    patched = text
      .gsub(/-l"MediaPipeTasksCommon"/, '-framework "MediaPipeTasksCommon"')
      .gsub(/-l"MediaPipeTasksVision"/, '-framework "MediaPipeTasksVision"')
    unless patched.include?('FRAMEWORK_SEARCH_PATHS[sdk=iphoneos*]')
      patched += "\nFRAMEWORK_SEARCH_PATHS[sdk=iphoneos*] = $(inherited) #{device_paths}\n"
      patched += "FRAMEWORK_SEARCH_PATHS[sdk=iphonesimulator*] = $(inherited) #{sim_paths}\n"
    end
    File.write(xcconfig, patched) if patched != text
  end
end
